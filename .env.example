# Copia come .env.local e compila (non committare segreti).
# Su Vercel aggiungi le stesse chiavi in Environment Variables (Production + Preview se serve).

# URL pubblico del sito (sitemap / robots). Es: https://www.gianago.com
NEXT_PUBLIC_SITE_URL=https://www.gianago.com

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt

# Solo ambiente server
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt

# Connection string Postgres (pooler Supabase o Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Pannello /admin — solo server (non commitare password reali)
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=your-secure-password
# Chiave per firmare il cookie di sessione (es. openssl rand -hex 32)
ADMIN_AUTH_SECRET=your-long-random-secret
